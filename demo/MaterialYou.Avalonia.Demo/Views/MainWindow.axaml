<Window
    x:Class="MaterialYou.Avalonia.Demo.Views.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="MaterialYou.Avalonia Demo"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16">
        <TextBlock Text="MaterialYou.Avalonia"
                   FontSize="28" FontWeight="Bold"
                   HorizontalAlignment="Center" />
        <TextBlock Text="Material Design 3 theme for Avalonia UI"
                   FontSize="16"
                   HorizontalAlignment="Center" />
        <TextBlock Text="Controls coming in subsequent issues."
                   FontSize="14"
                   HorizontalAlignment="Center" />
    </StackPanel>
</Window>
