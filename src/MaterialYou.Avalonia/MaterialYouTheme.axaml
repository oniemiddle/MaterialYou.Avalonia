<Styles x:Class="MaterialYou.Avalonia.MaterialYouTheme"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StyleInclude Source="/Tokens/TypeScale.axaml" />
    <Styles.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="/Tokens/_index.axaml" />
                <ResourceInclude Source="/Controls/_index.axaml" />
                <ResourceInclude Source="/Locale/zh-cn.axaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Styles.Resources>
</Styles>
