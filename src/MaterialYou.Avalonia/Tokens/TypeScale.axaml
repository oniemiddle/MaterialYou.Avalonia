<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- MD3 Type Scale: Display -->
    <Style Selector="TextBlock.DisplayLarge">
        <Setter Property="FontSize" Value="57" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="LineHeight" Value="64" />
        <Setter Property="LetterSpacing" Value="-0.25" />
    </Style>
    <Style Selector="TextBlock.DisplayMedium">
        <Setter Property="FontSize" Value="45" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="LineHeight" Value="52" />
    </Style>
    <Style Selector="TextBlock.DisplaySmall">
        <Setter Property="FontSize" Value="36" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="LineHeight" Value="44" />
    </Style>

    <!-- MD3 Type Scale: Headline -->
    <Style Selector="TextBlock.HeadlineLarge">
        <Setter Property="FontSize" Value="32" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="LineHeight" Value="40" />
    </Style>
    <Style Selector="TextBlock.HeadlineMedium">
        <Setter Property="FontSize" Value="28" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="LineHeight" Value="36" />
    </Style>
    <Style Selector="TextBlock.HeadlineSmall">
        <Setter Property="FontSize" Value="24" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="LineHeight" Value="32" />
    </Style>

    <!-- MD3 Type Scale: Title -->
    <Style Selector="TextBlock.TitleLarge">
        <Setter Property="FontSize" Value="22" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="LineHeight" Value="28" />
    </Style>
    <Style Selector="TextBlock.TitleMedium">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="LineHeight" Value="24" />
        <Setter Property="LetterSpacing" Value="0.15" />
    </Style>
    <Style Selector="TextBlock.TitleSmall">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="LineHeight" Value="20" />
        <Setter Property="LetterSpacing" Value="0.1" />
    </Style>

    <!-- MD3 Type Scale: Body -->
    <Style Selector="TextBlock.BodyLarge">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="LineHeight" Value="24" />
        <Setter Property="LetterSpacing" Value="0.5" />
    </Style>
    <Style Selector="TextBlock.BodyMedium">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="LineHeight" Value="20" />
        <Setter Property="LetterSpacing" Value="0.25" />
    </Style>
    <Style Selector="TextBlock.BodySmall">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="LineHeight" Value="16" />
        <Setter Property="LetterSpacing" Value="0.4" />
    </Style>

    <!-- MD3 Type Scale: Label -->
    <Style Selector="TextBlock.LabelLarge">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="LineHeight" Value="20" />
        <Setter Property="LetterSpacing" Value="0.1" />
    </Style>
    <Style Selector="TextBlock.LabelMedium">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="LineHeight" Value="16" />
        <Setter Property="LetterSpacing" Value="0.5" />
    </Style>
    <Style Selector="TextBlock.LabelSmall">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="LineHeight" Value="16" />
        <Setter Property="LetterSpacing" Value="0.5" />
    </Style>
</Styles>
